# Proxy / gateway shared secret (generate with: openssl rand -hex 32)
GATEWAY_SECRET=

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=

# Per-worker secrets — each agent gets a unique secret
# Cross-worker requests with the wrong secret return 401
WORKER_SECRET_DEVELOPER=
WORKER_SECRET_RESEARCHER=
WORKER_SECRET_DESIGNER=
WORKER_SECRET_SECURITY=
WORKER_SECRET_GIS=
WORKER_SECRET_PEER_REVIEW=

# Anthropic — injected by the proxy; agents never see this directly
ANTHROPIC_API_KEY=

# Optional: additional credential references configured in proxy.yaml
# OPENAI_API_KEY=
# GITHUB_TOKEN=
# BRAVE_API_KEY=
